{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
  ],
  enabledManagers: [
    'github-actions',
    'pep621',
    // Required for customManagers below to run at all: when enabledManagers is
    // set, custom managers are only active if listed here.
    'custom.regex',
  ],
  customManagers: [
    {
      customType: 'regex',
      description: 'Keep the pinned uv version in the workflows up to date',
      managerFilePatterns: [
        '/^\\.github/workflows/.+\\.ya?ml$/',
      ],
      matchStrings: [
        'UV_VERSION:\\s*["\']?(?<currentValue>\\d+\\.\\d+\\.\\d+)["\']?',
      ],
      // github-releases matches what setup-uv actually installs (the published
      // CLI binaries), rather than uv's secondary PyPI distribution. uv tags are
      // plain versions like 0.11.28, so no extractVersionTemplate is needed.
      depNameTemplate: 'astral-sh/uv',
      datasourceTemplate: 'github-releases',
    },
  ],
  prConcurrentLimit: 15,
  timezone: 'Europe/Berlin',
  schedule: [
    'before 4am on monday',
  ],
  constraints: {
    python: '>=3.11',
  },
  semanticCommits: 'enabled',
  lockFileMaintenance: {
    enabled: true,
    automerge: true,
    automergeType: 'pr',
  },
  // Security fixes are handled here rather than through packageRules. The
  // previous `matchCategories: ['security']` rules never matched anything:
  // categories are ecosystems such as 'python', not a severity, so Renovate
  // opened no vulnerability PRs at all while 34 Dependabot alerts were open.
  vulnerabilityAlerts: {
    enabled: true,
    labels: [
      'security',
    ],
    // Deliberately no semanticCommitType here. config:recommended brings
    // :semanticPrefixFixDepsChoreOthers, which already types project.dependencies
    // and project.optional-dependencies as `fix` and everything else, including
    // dependency-groups, as `chore`. Forcing `fix` would turn a CVE in a
    // development tool such as pytest into a user-facing patch release, even
    // though nobody installing the package is affected.
    // Vulnerability PRs default to updating only the lock file, which would
    // leave a vulnerable `>=` floor in pyproject.toml untouched -- exactly the
    // gap that had to be closed by hand in #860.
    rangeStrategy: 'bump',
    // Never wait for the weekly window, and never merge a security fix unread.
    schedule: [],
    automerge: false,
  },
  packageRules: [
    {
      matchManagers: [
        'github-actions',
      ],
      groupName: 'github-actions-updates',
      matchPackageNames: [
        '/.*/',
      ],
      // Actions are CI tooling, like the pinned uv version below. Without this
      // they default to chore(deps), which is inconsistent for the same kind of
      // change.
      semanticCommitType: 'ci',
    },
    {
      // The github-actions rule above cannot match this: the dependency comes
      // from the custom.regex manager. Without this, Renovate would default to
      // chore(deps) even though the pinned uv version is workflow tooling.
      description: 'Pinned uv version in workflows is CI tooling',
      matchManagers: [
        'custom.regex',
      ],
      matchDepNames: [
        'astral-sh/uv',
      ],
      semanticCommitType: 'ci',
      semanticCommitScope: 'deps',
    },
    {
      description: 'Customize lockFileMaintenance PR labels/grouping',
      matchUpdateTypes: [
        'lockFileMaintenance',
      ],
      labels: [
        'dependencies',
        'lock-file',
      ],
      groupName: 'lock-file-maintenance',
    },
    {
      description: 'Dev dependency groups: automerge minor and patch',
      matchManagers: [
        'pep621',
      ],
      matchJsonata: [
        "depType = 'dependency-groups' and managerData.depGroup in ['dev','docs','mypy','pre-commit','safety','tests','typeguard','xdocs']",
      ],
      matchUpdateTypes: [
        'minor',
        'patch',
      ],
      groupName: 'uv-updates-dev',
      automerge: true,
      automergeType: 'pr',
    },
  ],
}
